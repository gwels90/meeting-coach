# Fathom (get from Fathom > Settings > API Access)
FATHOM_API_KEY=your-api-key-here
FATHOM_WEBHOOK_SECRET=whsec_your-secret-here

# Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Resend (get from resend.com/api-keys)
RESEND_API_KEY=re_...
EMAIL_TO=gilbert@valveman.com
EMAIL_FROM=Meeting Coach <onboarding@resend.dev>

# Polling interval in ms (default: 120000 = 2 minutes)
POLL_INTERVAL_MS=120000

# Server
PORT=3000

# Admin dashboard password
ADMIN_PASSWORD=your-admin-password-here

# GitHub archive — writes transcripts + scorecards to a private repo
# organized by user name. Fine-grained PAT scoped to ONLY this one repo,
# with Contents: Read and write permission.
GITHUB_TOKEN=github_pat_...
GITHUB_ARCHIVE_REPO=gwels90/meeting-coach-archive
